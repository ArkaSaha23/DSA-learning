class Solution {
    public int subarraySum(int[] nums, int k) {
         int n = nums.length;
         int prefixSum[] = new int[n];
         HashMap<Integer,Integer> map = new HashMap<>();

         //calculate the prefix sum
         prefixSum[0] = nums[0];
         for(int i=1;i<n;i++){
            prefixSum[i] = prefixSum[i-1] + nums[i];
         }

         //counting subarrays
         int count=0;
         for(int j=0;j<n;j++){
            if(prefixSum[j] == k) count++;      //if the current prefixSum[i] = k, incr count by 1
            int val = prefixSum[j] - k;         //IMPORTANT FORMULA for prefix sum
            if(map.containsKey(val)){             //if true, then get the value from map and incr it by 1
                count= count + map.get(val);
            }
            map.put(prefixSum[j], map.getOrDefault(prefixSum[j],0)+1);      //if above contition false then add the prefixSum[j] in the map
         }
         return count;
    }
}
