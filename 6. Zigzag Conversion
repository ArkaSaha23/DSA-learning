class Solution {
    public String convert(String s, int numRows) {
        String newstr="";
        String arr[]=new String[numRows];
        for(int i=0;i<numRows;i++)
        {
            arr[i]="";
        }
        int i=0;
        while(i<s.length())
        {
            for(int j=0;j<numRows && i<s.length() ;j++){
                System.out.print(j+" ");
                arr[j]=arr[j]+s.charAt(i);
                i++;
            }
            for(int j=numRows-2;j>0 && i<s.length() ;j--)
            {
                System.out.print(j+" ");
                arr[j]=arr[j]+s.charAt(i);
                i++;
            }
        }
        
        for(i=0;i<numRows;i++){
            newstr+=arr[i];
        }
        return(newstr);
    }
}
